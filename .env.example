# 开发 / 生产环境 API 基址（开发推荐 /api + Vite 代理，生产填完整 URL）
VITE_API_BASE_URL=/api

# 团队默认代理目标（提交到仓库的配置，见 .env.development）
# VITE_DEV_API_PROXY=http://192.168.1.10:3000
# VITE_BACKEND_ORIGIN=http://192.168.1.10:3000

# 个人本地联调：复制下面两行到 .env.development.local（该文件已被 git 忽略，不会发给别人）
VITE_DEV_API_PROXY=http://127.0.0.1:3000
VITE_BACKEND_ORIGIN=http://127.0.0.1:3000

# 调度大屏 HTML 地址
# VITE_DISPATCH_MAP_URL=http://127.0.0.1:8080/dispatch_map.html
