# 开发环境 API：走 Vite 代理 /api → VITE_DEV_API_PROXY，避免跨域
VITE_API_BASE_URL=/api

# 代理目标（团队默认：.10 正式数据；个人测本机后端见 .env.development.local）
VITE_DEV_API_PROXY=http://192.168.1.10:3000

# 图片/证照等静态资源 origin（与代理目标一致，勿带 /api 后缀）
VITE_BACKEND_ORIGIN=http://192.168.1.10:3000

# 调度大屏 HTML 地址（地图调度端独立部署时的完整 URL）
# VITE_DISPATCH_MAP_URL=http://127.0.0.1:8080/dispatch_map.html
